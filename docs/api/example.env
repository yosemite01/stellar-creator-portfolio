# Stellar API — copy to .env.local or import into Postman environment
# Published with collection: see docs/api/README.md

# Base URL for all HTTP requests (no trailing slash)
BASE_URL=http://localhost:3000

# Bearer token — use when your gateway or future JWT layer sends Authorization: Bearer <token>
# NextAuth session routes currently rely on cookies; set SESSION_TOKEN for cookie-based calls.
BEARER_TOKEN=

# Raw value of the NextAuth session cookie (optional, for Postman)
# In browser DevTools → Application → Cookies → copy value of `next-auth.session-token`
SESSION_TOKEN=

# Used by referral links in API responses
NEXT_PUBLIC_APP_URL=http://localhost:3000
