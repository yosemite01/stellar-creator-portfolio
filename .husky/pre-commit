#!/usr/bin/env sh
. "$(dirname "$0")/_/husky.sh"

MAX_SIZE=10485760 # 10MB

# ---------------------------------------------------------------------------
# Block .env files from being committed (issue #718)
# Only .env.example files are permitted — everything else is a secret leak.
# ---------------------------------------------------------------------------
STAGED_ENV=$(git diff --cached --name-only --diff-filter=ACM | grep -E '(^|/)\.env(\.[^e]|$)' | grep -v '\.env\.example$')
if [ -n "$STAGED_ENV" ]; then
  echo "🚨 BLOCKED: The following .env file(s) must never be committed:"
  echo "$STAGED_ENV" | sed 's/^/   /'
  echo ""
  echo "  ✅ Commit .env.example with placeholder values instead."
  echo "  ✅ Add the real .env to .gitignore."
  echo "  ✅ Store secrets in GitHub Actions Secrets or AWS Secrets Manager."
  exit 1
fi

# Use a temporary file to store the list of changed files
TMP_FILE=$(mktemp)
git diff --cached --name-only --diff-filter=ACM > "$TMP_FILE"

HAS_ERROR=0

while IFS= read -r file; do
  if [ -f "$file" ]; then
    size=$(wc -c < "$file" 2>/dev/null || echo 0)
    if [ "$size" -gt "$MAX_SIZE" ]; then
      echo "🚨 Error: File '$file' is too large! ($size bytes)"
      echo "Maximum allowed commit size per file is 10MB."
      echo "Please remove it from your commit."
      HAS_ERROR=1
    fi
  fi
done < "$TMP_FILE"

rm -f "$TMP_FILE"

if [ "$HAS_ERROR" -eq 1 ]; then
  exit 1
fi

# 1. TypeScript type check (incremental)
echo "📝 Running TypeScript type check..."
pnpm exec tsc --noEmit --incremental || exit 1

# 2. Rust Clippy on changed .rs files only
if git diff --cached --name-only | grep -q '\.rs$'; then
  echo "🔍 Running Rust Clippy..."
  cd backend && cargo clippy --all-targets -- -D warnings || exit 1
  cd ..
fi

# 3. Secret scanning with gitleaks
echo "🔐 Scanning for secrets..."
pnpm exec gitleaks protect --staged --redact || exit 1

# 4. SQL migration safety check — block DROP TABLE without IF EXISTS
if git diff --cached --name-only | grep -qE '\.(sql|prisma)$'; then
  if git diff --cached | grep -q 'DROP TABLE'; then
    if ! git diff --cached | grep -q 'DROP TABLE.*IF EXISTS'; then
      echo "⚠️  ERROR: Found DROP TABLE without IF EXISTS. Add IF EXISTS for safety."
      exit 1
    fi
  fi
fi
