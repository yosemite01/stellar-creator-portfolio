# ─── Authentication [REQUIRED] ────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here

# ─── Database [REQUIRED] ─────────────────────────────────────────────────────
DATABASE_URL=file:./dev.db

# ─── Supabase [REQUIRED] ─────────────────────────────────────────────────────
# Get these from your Supabase project: https://supabase.com/dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# ─── Redis [optional] ────────────────────────────────────────────────────────
# Omit for in-memory fallback cache (fine for dev)
REDIS_URL=redis://localhost:6379

# ─── Email [optional] ────────────────────────────────────────────────────────
# SMTP URL format: smtp://user:pass@host:port  or  smtps://user:pass@host:465
# Omit for Ethereal test account fallback
EMAIL_SERVER=smtp://localhost:1025
EMAIL_FROM="Stellar Creators <noreply@stellar-creators.com>"
# Dev-only: Ethereal test account (https://ethereal.email)
EMAIL_DEV_USER=
EMAIL_DEV_PASS=

# ─── Resend [optional] ──────────────────────────────────────────────────────
# If set, Resend is used instead of Nodemailer for email delivery
RESEND_API_KEY=

# ─── GitHub OAuth [optional] ─────────────────────────────────────────────────
GITHUB_ID=your-github-client-id
GITHUB_SECRET=your-github-client-secret

# ─── Stripe Payments [optional] ──────────────────────────────────────────────
# Omit to disable payment features (escrow, subscriptions)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM_MONTHLY=price_...

# ─── S3 / R2 Storage [optional] ──────────────────────────────────────────────
# If any S3 var is set, BUCKET + ACCESS_KEY_ID + SECRET_ACCESS_KEY are all required
STORAGE_PROVIDER=s3
S3_BUCKET=your-bucket-name
S3_REGION=us-east-1
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
SIGNED_URL_TTL_SECONDS=900

# ─── Stellar / Soroban [optional] ────────────────────────────────────────────
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
STELLAR_ADMIN_SECRET=
BOUNTY_CONTRACT_ID=
ESCROW_CONTRACT_ID=
FREELANCER_CONTRACT_ID=
GOVERNANCE_CONTRACT_ID=

# ─── Upload [optional] ───────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=100
ALLOWED_FILE_TYPES=
NEXT_PUBLIC_MAX_UPLOAD_SIZE_MB=100

# ─── Analytics [optional] ────────────────────────────────────────────────────
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=example.com
NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/plausible.js
NEXT_PUBLIC_PLAUSIBLE_API=https://plausible.io/api/event
PLAUSIBLE_API_KEY=
ADMIN_DASHBOARD_TOKEN=

# ─── PWA / Push Notifications [optional] ─────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ─── Notifications [optional] ────────────────────────────────────────────────
BOUNTY_NOTIFY_EMAIL=

# ─── Application [optional] ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
PORT=3000
