{
  "name": "api-security",
  "version": "1.0.0",
  "description": "Enterprise-grade API security middleware for rate limiting, authentication, and protection",
  "main": "index.ts",
  "scripts": {
    "test": "ts-node -O '{\"module\":\"commonjs\"}' tests/runner.ts",
    "test:unit": "ts-node -O '{\"module\":\"commonjs\"}' tests/unit/runner.ts",
    "test:integration": "ts-node -O '{\"module\":\"commonjs\"}' tests/integration/runner.ts",
    "test:e2e": "ts-node -O '{\"module\":\"commonjs\"}' tests/e2e/runner.ts",
    "test:security": "ts-node -O '{\"module\":\"commonjs\"}' tests/security/runner.ts",
    "build": "tsc",
    "dev": "ts-node index.ts",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.ts\""
  },
  "dependencies": {
    "express": "^4.18.2",
    "compression": "^1.7.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.0.0",
    "@types/compression": "^1.7.2",
    "typescript": "^5.0.0",
    "ts-node": "^10.9.0",
    "eslint": "^8.40.0",
    "@typescript-eslint/eslint-plugin": "^5.57.0",
    "@typescript-eslint/parser": "^5.57.0",
    "prettier": "^2.8.8"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
