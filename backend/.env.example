# =============================================================================
# Stellar Platform – Backend Environment Variables
# Copy this file to .env and fill in the values for your environment.
# =============================================================================

# -----------------------------------------------------------------------------
# API Service
# -----------------------------------------------------------------------------
API_HOST=127.0.0.1
API_PORT=3001

# -----------------------------------------------------------------------------
# Auth Service
# -----------------------------------------------------------------------------
AUTH_HOST=127.0.0.1
AUTH_PORT=3002
JWT_SECRET=change-me-in-production

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://stellar:stellar_dev_password@localhost:5432/stellar_db
DATABASE_MAX_CONNECTIONS=10
SLOW_QUERY_THRESHOLD_MS=1000

# -----------------------------------------------------------------------------
# Cache (Redis)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Stellar / Soroban Network
# -----------------------------------------------------------------------------
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Webhooks
# -----------------------------------------------------------------------------
WEBHOOK_SECRET=change-me-in-production

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
RUST_LOG=info,stellar_api=debug,stellar_auth=debug

# -----------------------------------------------------------------------------
# ELK Stack (Elasticsearch · Logstash · Kibana)
# -----------------------------------------------------------------------------
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=change-me-in-production
LOGSTASH_HOST=localhost
LOGSTASH_PORT=5044
KIBANA_URL=http://localhost:5601
