# ── API Service ──────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=3001

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgres://stellar:stellar_dev_password@localhost:5432/stellar_db

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Stellar / Soroban ────────────────────────────────────────
STELLAR_NETWORK=testnet
# Options: testnet | futurenet | mainnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Contract addresses (populated after deployment)
# Contract addresses (populated after deployment)
BOUNTY_CONTRACT_ID=
ESCROW_CONTRACT_ID=
FREELANCER_CONTRACT_ID=
GOVERNANCE_CONTRACT_ID=

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production
JWT_EXPIRY_SECONDS=3600

# ── File Uploads ────────────────────────────────────────────
# Local storage directory (default: ./uploads)
UPLOAD_DIR=./uploads
# Max file size in bytes (default: 10485760 = 10 MB)
UPLOAD_MAX_FILE_SIZE=10485760
# Comma-separated allowed MIME types
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp,image/gif,application/pdf
# S3 storage (optional — when set, files go to S3 instead of local disk)
# UPLOAD_S3_BUCKET=
# UPLOAD_S3_REGION=us-east-1
# UPLOAD_S3_ENDPOINT=

# ── Logging ──────────────────────────────────────────────────
RUST_LOG=info,stellar_api=debug,stellar_indexer=debug

# ── Indexer ───────────────────────────────────────────────────
# Ledgers to fetch per RPC poll (default 100)
INDEXER_LEDGER_CHUNK=100
# Seconds between polls — Stellar closes a ledger every ~5-6 s (default 6)
INDEXER_POLL_INTERVAL_SECS=6
