# ── API Service ──────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=3001

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgres://stellar:stellar_dev_password@localhost:5432/stellar_db

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Stellar / Soroban ────────────────────────────────────────
STELLAR_NETWORK=testnet
# Options: testnet | futurenet | mainnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Contract addresses (populated after deployment)
# Contract addresses (populated after deployment)
BOUNTY_CONTRACT_ID=
ESCROW_CONTRACT_ID=
FREELANCER_CONTRACT_ID=
GOVERNANCE_CONTRACT_ID=

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production
JWT_EXPIRY_SECONDS=3600

# ── Service Discovery ──────────────────────────────────────────
# Set CONSUL_HTTP_ADDR to enable Consul-based service discovery.
# When unset, the static/env fallback is used (suitable for local dev).
# CONSUL_HTTP_ADDR=http://localhost:8500
#
# Static discovery overrides (used when Consul is not configured):
# DISCOVERY_STELLAR_API_URL=http://127.0.0.1:3001
# DISCOVERY_STELLAR_AUTH_URL=http://127.0.0.1:8080
# DISCOVERY_STELLAR_INDEXER_URL=http://127.0.0.1:9000
# DISCOVERY_STELLAR_NOTIFICATIONS_URL=http://127.0.0.1:9001

# ── Logging ──────────────────────────────────────────────────
RUST_LOG=info,stellar_api=debug,stellar_indexer=debug

# ── Indexer ───────────────────────────────────────────────────
# Ledgers to fetch per RPC poll (default 100)
INDEXER_LEDGER_CHUNK=100
# Seconds between polls — Stellar closes a ledger every ~5-6 s (default 6)
INDEXER_POLL_INTERVAL_SECS=6
