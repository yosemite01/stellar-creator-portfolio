# ---------------------------------------------------------------------------
# backend/services/api — environment template
# Copy to .env and fill in real values. NEVER commit .env.
# In production, inject these via GitHub Actions Secrets or AWS Secrets Manager.
# ---------------------------------------------------------------------------

# Database — PgBouncer pooler URL (port 6432) for runtime queries.
# Use ?pgbouncer=true and connection_limit=1 with Supabase's built-in pooler.
DATABASE_URL=postgres://stellar:CHANGE_ME@localhost:5432/stellar_db

# API server binding
API_HOST=127.0.0.1
API_PORT=3001

# Connection pool tuning
DB_POOL_MAX_CONNECTIONS=10
DB_POOL_IDLE_TIMEOUT=300

# Observability
SLOW_QUERY_THRESHOLD_MS=1000
RUST_LOG=info,stellar_api=debug

# WebSocket limits
WS_MAX_CONNECTIONS_PER_IP=10
WS_MAX_CONNECTIONS_GLOBAL=500
