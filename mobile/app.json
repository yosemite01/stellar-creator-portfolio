{
  "expo": {
    "name": "Stellar",
    "slug": "stellar-creator-portfolio",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "assetBundlePatterns": ["**/*"],
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.stellar.creatorportfolio",
      "associatedDomains": ["applinks:stellar.app", "applinks:www.stellar.app"],
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Stellar needs access to your photo library to upload portfolio images.",
        "NSCameraUsageDescription": "Stellar needs camera access to capture portfolio photos.",
        "NSPhotoLibraryAddUsageDescription": "Stellar needs permission to save photos to your library.",
        "NSFaceIDUsageDescription": "Stellar uses Face ID or Touch ID to securely authenticate portfolio access."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.stellar.creatorportfolio",
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "CAMERA",
        "READ_MEDIA_IMAGES"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "stellar.app",
              "pathPrefix": "/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        },
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "stellar",
              "host": "wc"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "scheme": "stellar",
    "plugins": [
      "expo-router",
      "expo-localization",
      "@react-native-async-storage/async-storage",
      "expo-network",
      [
        "expo-image-picker",
        {
          "photosPermission": "Stellar needs access to your photo library to upload portfolio images.",
          "cameraPermission": "Stellar needs camera access to capture and upload portfolio photos.",
          "microphonePermission": "Stellar needs microphone access to record portfolio videos."
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": { "newArchEnabled": true },
          "android": { "newArchEnabled": true }
        }
      ]
    ],
    "extra": {
      "eas": { "projectId": "stellar-creator-portfolio" }
    }
  }
}
